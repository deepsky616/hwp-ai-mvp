{
  "name": "hwp-ai-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "desktop/electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "desktop:dev": "electron desktop/electron/main.cjs",
    "desktop:win": "electron-builder --win nsis portable",
    "desktop:mac": "electron-builder --mac dmg"
  },
  "dependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "kordoc": "^2.8.0",
    "next": "^15.1.3",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1"
  },
  "vitest": {
    "environment": "jsdom"
  },
  "build": {
    "appId": "kr.hwpai.editor",
    "productName": "HWP AI 편집기",
    "files": [
      ".next/**/*",
      "app/**/*",
      "desktop/**/*",
      "lib/**/*",
      "public/**/*",
      "scripts/**/*",
      "next.config.ts",
      "package.json",
      "tsconfig.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-windows-setup-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-portable-${arch}.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "identity": null,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    }
  }
}
